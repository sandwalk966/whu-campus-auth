# ===========================================
# 环境变量配置文件
# ===========================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 修改 .env 中的配置值
# 3. 程序会自动读取 .env 文件
#
# 优先级：环境变量 > .env > config.yaml
# ===========================================

# -------------------------------------------
# 服务器配置
# -------------------------------------------
SERVER_PORT=8888
GIN_MODE=release

# -------------------------------------------
# CORS 配置
# -------------------------------------------
# 允许的域名列表（逗号分隔）
# 生产环境：https://yourdomain.com,https://www.yourdomain.com
# 开发环境：http://localhost:3000,http://localhost:5173
# 留空表示只允许 HTTPS 请求和 Nginx 反向代理
ALLOWED_ORIGINS=

# -------------------------------------------
# 数据库配置
# -------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_NAME=whu_campus_auth
DB_USER=root
DB_PASSWORD=root

# -------------------------------------------
# Redis 配置
# -------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -------------------------------------------
# JWT 配置
# -------------------------------------------
# 生产环境必须修改为随机密钥！
JWT_SECRET=your-secret-key-change-in-production
# JWT 过期时间（秒）默认 24 小时
JWT_EXPIRE=86400

# -------------------------------------------
# 日志配置
# -------------------------------------------
# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# -------------------------------------------
# 文件上传配置
# -------------------------------------------
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE=10485760
